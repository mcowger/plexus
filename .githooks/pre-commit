#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

# --- Require bun install for Vitest transition (2025-04-18 cutoff) ---
BUN_LOCKFILE="$repo_root/bun.lockb"
CUTOFF_DATE="2025-04-18"

if [ -f "$BUN_LOCKFILE" ]; then
  BUN_LOCK_MTIME=$(stat -f "%Sm" -t "%Y-%m-%d" "$BUN_LOCKFILE" 2>/dev/null || stat -c "%y" "$BUN_LOCKFILE" 2>/dev/null | cut -d' ' -f1 || echo "1970-01-01")
  if [ "$BUN_LOCK_MTIME" \< "$CUTOFF_DATE" ]; then
    echo ""
    echo "[pre-commit] ERROR: bun.lockb is from $BUN_LOCK_MTIME, before $CUTOFF_DATE."
    echo ""
    echo "The project switched to Vitest for testing. You need to run:"
    echo ""
    echo "    bun install"
    echo ""
    echo "This updates git hooks and installs Vitest."
    echo ""
    exit 1
  fi
fi

# --- Block migration file commits (CI auto-generates these) ---
if [ "${CI:-}" != "true" ] && [ "${ALLOW_MIGRATIONS:-}" != "1" ]; then
  migration_files=$(git diff --cached --name-only -- \
    'packages/backend/drizzle/migrations/' \
    'packages/backend/drizzle/migrations_pg/' || true)
  if [ -n "$migration_files" ]; then
    echo ""
    echo "[pre-commit] ERROR: Migration files should not be committed manually."
    echo "Migrations are auto-generated on main by CI after schema changes merge."
    echo ""
    echo "Blocked files:"
    echo "$migration_files" | sed 's/^/  /'
    echo ""
    echo "To remove them from your commit:  git reset HEAD -- packages/backend/drizzle/migrations/ packages/backend/drizzle/migrations_pg/"
    echo "To bypass (maintainers only):     ALLOW_MIGRATIONS=1 git commit ..."
    echo ""
    exit 1
  fi
fi

# --- Validate GitHub Actions workflow YAML ---
workflow_files=$(git diff --cached --name-only -- '.github/workflows/*.yml' '.github/workflows/*.yaml' || true)
if [ -n "$workflow_files" ]; then
  echo "[pre-commit] Validating workflow YAML files..."
  for f in $workflow_files; do
    if [ -f "$repo_root/$f" ]; then
      if ! bun -e "const fs=require('fs');const yaml=require('$repo_root/packages/backend/node_modules/yaml');try{yaml.parse(fs.readFileSync('$repo_root/$f','utf8'));console.log('  ✓ $f')}catch(e){console.error('  ✗ $f:',e.message);process.exit(1)}" 2>&1; then
        echo "[pre-commit] ERROR: Invalid YAML in $f"
        exit 1
      fi
    fi
  done
fi

# --- Run Biome formatter on staged files ---
staged_files=$(git diff --cached --name-only --diff-filter=ACM -- '*.ts' '*.tsx' '*.js' '*.jsx' '*.json' || true)
if [ -n "$staged_files" ]; then
  echo "[pre-commit] Running Biome formatter on staged files..."
  echo "$staged_files" | xargs bunx biome format --write
  echo "$staged_files" | xargs git add
fi

# --- Run Biome linter on all source files ---
echo "[pre-commit] Running Biome linter..."
bunx biome lint . || { echo "[pre-commit] Linting errors - fix with: bun run format"; exit 1; }

# --- Run TypeScript type check on all packages ---
echo "[pre-commit] Running TypeScript type check..."
bun run typecheck || { echo "[pre-commit] Type errors - fix with: bun run typecheck"; exit 1; }

# --- Build frontend (catches invalid imports, missing exports, broken builds) ---
frontend_files=$(git diff --cached --name-only --diff-filter=ACM -- 'packages/frontend/src/**' || true)
if [ -n "$frontend_files" ]; then
  echo "[pre-commit] Frontend files changed — running build:frontend..."
  bun run build:frontend
fi

echo "[pre-commit] Running backend tests..."
cd packages/backend
bun run test
