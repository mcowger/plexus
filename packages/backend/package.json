{
  "name": "plexus-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "typecheck": "bun x tsc --noEmit",
    "test": "bunx --bun vitest run --config vitest.config.ts --changed HEAD",
    "test:force-all": "bunx --bun vitest run --config vitest.config.ts",
    "test:watch": "bunx --bun vitest --config vitest.config.ts",
    "rekey": "bun run src/cli/rekey.ts",
    "backup": "bun run src/cli/backup.ts"
  },
  "dependencies": {
    "@fastify/bearer-auth": "^10.1.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@google/genai": "^1.52.0",
    "@mariozechner/pi-ai": "0.72.1",
    "@plexus/shared": "workspace:*",
    "@sinclair/typebox": "^0.34.49",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "eventsource-encoder": "^1.0.2",
    "eventsource-parser": "^3.0.8",
    "fastify": "^5.8.5",
    "js-tiktoken": "^1.0.21",
    "parse-duration": "^2.1.6",
    "pkce-challenge": "^6.0.0",
    "postgres": "^3.4.9",
    "winston": "^3.19.0",
    "winston-transport": "^4.9.0",
    "yaml": "^2.8.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.5",
    "@types/bun": "latest",
    "@types/node": "^25.6.0",
    "@types/winston": "^2.4.4",
    "drizzle-kit": "^0.31.10",
    "form-data": "^4.0.5"
  }
}
